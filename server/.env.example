# ── ローカル開発（個別指定） ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=accounting

# ── 本番(Railway等) ──
# Railwayのmysqlプラグインが提供する接続URLを設定すれば上のDB_*は不要
# MYSQL_URL=mysql://user:password@host:port/railway

# フロント(本番Vercel)のURLをカンマ区切りで許可
# CLIENT_ORIGIN=https://your-app.vercel.app,http://localhost:5173

# Railwayが自動で割り当てるポート（手動設定不要）
# PORT=3001
